# === Telegram (https://my.telegram.org -> API development tools) ===
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Telethon session name/path (a .session file will be created on first login)
TELEGRAM_SESSION=telegram_pionex_bot
# Comma-separated list of channel/group usernames or numeric chat IDs to monitor
TELEGRAM_CHAT_IDS=

# === Pionex API (https://www.pionex.com -> API Management) ===
PIONEX_API_KEY=
PIONEX_API_SECRET=
# Override only if Pionex changes their API host
PIONEX_BASE_URL=https://api.pionex.com

# === Safety switch ===
# Must be explicitly "true" AND main.py must be started with --live for
# real orders to be sent to Pionex. Anything else stays in dry-run/paper mode.
LIVE_TRADING=false

# Path to the YAML trading settings file (position sizing, risk limits, parser rules)
SETTINGS_FILE=config/settings.yaml

# Where to store the SQLite trade/signal log
DB_PATH=data/trading.db
